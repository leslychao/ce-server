# On Linux, set these to the output of: id -u && id -g
STEAM_UID=1000
STEAM_GID=1000

UPDATE_ON_START=true

SERVER_NAME=Conan Exiles Enhanced Server
# Empty means a public server. Do not commit the real password.
SERVER_PASSWORD=
# Empty leaves the existing admin password unchanged.
ADMIN_PASSWORD=

GAME_PORT=7777
PING_PORT=7778
QUERY_PORT=27015
MAX_PLAYERS=20

# RCON is disabled and not published by compose.yaml by default.
RCON_ENABLED=false
RCON_PORT=25575
RCON_PASSWORD=
